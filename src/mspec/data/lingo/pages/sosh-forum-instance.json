                    },
                    "result": {
                        "type": "struct",
                        "value": {
                            "forum": {
                                "type": "struct",
                                "value": {}
                            },
                            "threads": {
                                "type": "list",
                                "value": []
                            }
                        },
                        "tests": {
                            "test_cases": []
                        }
                    }
                }
            }
        },
        "op_view_state": {
            "type": "struct",
            "default": {
                "state": "initial",
                "error": "",
                "data": {},
