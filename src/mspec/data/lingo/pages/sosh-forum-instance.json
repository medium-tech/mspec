    },
    "ops": {
		"is_loaded": {
			"args": {},
			"func": {
				"branch": [
                    {
                        "if": {
                            "call": "eq",
                            "args": {
                                "a": {
                                    "call": "key",
                                    "args": {
                                        "object": {"state": {"op_view_state": {}}},
                                        "key": "state"
