                                    "call": "key",
                                    "args": {
                                        "object": {"state": {"op_view_state": {}}},
                                        "key": "state"
                                    }
                                },
                                "b": "result"
                            }
                        },
                        "then": {
                            "call": "key",
                            "args": {
                                "object": {"state": {"op_view_state": {}}},
                                "key": "result.value.threads.value.total"
                            }
                        }
                    },
					{
						"else": {
							"type": "int",
                            "value": -1
                        }
					}
				]
			}
		},
        "forum": {
            "type": "struct",
