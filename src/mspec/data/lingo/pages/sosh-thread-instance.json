    "ops": {
        "main_post_is_loaded": {
            "args": {},
            "func": {
                "branch": [
                    {
                        "if": {
                            "call": "eq",
                            "args": {
                                "a": {
                                    "call": "key",
                                    "args": {
                                        "object": {
                                            "state": {
                                                "thread_op_view_state": {}
                                            }
                                        },
