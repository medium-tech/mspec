        "prev_page": {
            "args": {},
            "func": {
                "call": "all",
                "args": {
                    "iterable": [
                        {
                            "set": {
                                "state": {
                                    "page_number": {}
                                }
                            },
                            "to": {
                                "call": "sub",
                                "args": {
                                    "a": {
                                        "state": {
                                            "page_number": {}
                                        }
                                    },
                                    "b": 1
                                }
                            }
                        },
                        {
                            "set": {
                                "state": {
                                    "replies_op_view_state": {
                                        "state": {}
                                    }
                                }
                            },
                            "to": "triggered"
                        }
                    ]
                }
            }
        },
        "next_page": {
            "args": {},
            "func": {
                "call": "all",
                "args": {
                    "iterable": [
                        {
                            "set": {
                                "state": {
                                    "page_number": {}
                                }
                            },
                            "to": {
                                "call": "add",
                                "args": {
                                    "a": {
                                        "state": {
                                            "page_number": {}
                                        }
                                    },
                                    "b": 1
                                }
                            }
                        },
                        {
                            "set": {
                                "state": {
                                    "replies_op_view_state": {
                                        "state": {}
                                    }
                                }
                            },
                            "to": "triggered"
                        }
                    ]
                }
            }
        },
        "last_page": {
            "args": {},
            "func": {
                "call": "max",
                "args": {
                    "a": {
                        "call": "floordiv",
                        "args": {
                            "a": {
                                "state": {
                                    "total_replies": {}
                                }
                            },
                            "b": {
                                "state": {
                                    "page_size": {}
                                }
                            }
                        }
                    },
                    "b": 1
                }
            }
        },
        "refresh": {
            "args": {},
            "func": {
				"set": {
					"state": {
						"replies_op_view_state": {
							"state": {}
						}
					}
				},
				"to": "triggered"
