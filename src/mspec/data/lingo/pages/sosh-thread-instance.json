                "state": "initial",
                "error": "",
                "data": {},
                "result": {
                    "type": "any",
                    "value": null
                }
            }
        },
		"overall_op_view_state": {
			"type": "str",
			"description": "state is either 'default', 'result' or 'error'. If thread_op_view_state and replies_op_view_state are result this will return result, if either are error it will return error, otherwise default",
			"calc": {
				"branch": [
					{
						"if": {
							"call": "and",
							"args": {
								"a": {
									"call": "eq",
									"args": {
										"a": {
											"call": "key",
											"args": {
												"object": {
													"state": {
														"thread_op_view_state": {}
													}
												},
												"key": "state"
											}
										},
										"b": "result"
									}
								},
								"b": {
									"call": "eq",
									"args": {
										"a": {
											"call": "key",
											"args": {
												"object": {
													"state": {
														"replies_op_view_state": {}
													}
												},
												"key": "state"
											}
										},
										"b": "result"
									}
								}
							}
						},
						"then": "result"
					},
					{
						"elif": {
							"call": "or",
							"args": {
								"a": {
									"call": "eq",
									"args": {
										"a": {
											"call": "key",
											"args": {
												"object": {
													"state": {
														"thread_op_view_state": {}
													}
												},
												"key": "state"
											}
										},
										"b": "error"
									}
								},
								"b": {
									"call": "eq",
									"args": {
										"a": {
											"call": "key",
											"args": {
												"object": {
													"state": {
														"replies_op_view_state": {}
													}
												},
												"key": "state"
											}
										},
										"b": "error"
									}
								}
							}
						},
						"then": "error"
					},
					{
						"else": "default"
					}
				]
			}
		},
		"error_message": {
			"type": "str",
			"description": "if state.overall_op_view_state is error, this will return the error message from either thread_op_view_state or replies_op_view_state",
			"default": "",
			"calc": {
				"branch": [
					{
						"if": {
							"call": "eq",
							"args": {
								"a": {
									"call": "key",
									"args": {
										"object": {
											"state": {
												"thread_op_view_state": {}
											}
										},
										"key": "state"
									}
								},
								"b": "error"
							}
						},
						"then": {
							"call": "key",
							"args": {
								"object": {
									"state": {
										"thread_op_view_state": {}
									}
								},
								"key": "error"
							}
						}
					},
					{
						"elif": {
							"call": "eq",
							"args": {
								"a": {
									"call": "key",
									"args": {
										"object": {
											"state": {
												"replies_op_view_state": {}
											}
										},
										"key": "state"
									}
								},
								"b": "error"
							}
						},
						"then": {
							"call": "key",
							"args": {
								"object": {
									"state": {
										"replies_op_view_state": {}
									}
								},
								"key": "error"
							}
						}
					},
					{
						"else": "no error"
					}
				]
			}
		},
