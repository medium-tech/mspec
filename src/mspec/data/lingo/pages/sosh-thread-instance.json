{
    "lingo": {
        "version": "page-beta-1",
        "parent_url": "/api/spec"
    },
    "params": {
        "project_name": {
            "name": {
                "lower_case": "project name"
            },
            "type": "str",
            "default": "My Lingo Project",
            "description": "Name of the Lingo project"
        },
        "module_name": {
            "name": {
                "lower_case": "module name"
            },
            "type": "str",
            "default": "my-module-a",
            "description": "Name of the module"
        },
		"model_definition": {
			"name": {
				"lower_case": "model definition"
			},
			"type": "model",
			"value": {
				"name": {
					"lower_case": "my model a"
				},
				"fields": {
					"user_id": {
						"name": {
							"lower_case": "user id"
						},
						"type": "str",
						"description": "ID of the user who created the thread"
					}
				}
			},
			"description": "placeholder"
		},
		"model_id": {
			"name": {
				"lower_case": "model id"
			},
			"type": "str",
			"default": "my-model-a",
			"description": "ID of the model to use for the thread"
		},
		"model_name": {
			"name": {
				"lower_case": "model name"
			},
			"type": "str",
			"default": "my-model-a",
			"description": "Name of the model"
		},
        "op_name": {
            "name": {
                "lower_case": "op name"
            },
            "type": "str",
            "default": "my-op-a",
            "description": "Name of the model"
        },
        "op_definition": {
            "name": {
                "lower_case": "op definition"
            },
            "default": {
				"type": "op",
				"value": {
				}
			}
        }
    },
    "state": {
        "op_view_state": {
            "type": "struct",
            "default": {
                "state": "initial",
                "error": "",
                "data": {},
                "result": {"type": "any", "value": null}
            }
        },
        "op_api_url": {
            "type": "str",
            "calc": {
                "call": "concat",
                "args": {
                    "items": [
                        "/api/",
                        {"params": {"module_name": {}}},
                        "/",
                        {"params": {"op_name": {}}}
                    ]
                }
            }
        },
        "header": {
            "type": "str",
            "calc": {
                "call": "join",
                "args": {
                    "separator": "",
                    "items": [":: ",{"params": {"op_name": {}}}]
                }
            }
        }
    },
    "ops": {},
    "output": [
        {"heading": ":: thread",  "level": 1},
        {"breadcrumbs": [
            {"params": {"project_name": {}}},
            {"params": {"module_name": {}}},
            {"params": {"op_name": {}}}
        ]},
        {"op": {
            "bind": {"state": {"op_view_state": {}}},
            "interactive": true,
            "http": {"state": {"op_api_url": {}}},
            "definition": {"params": {"op_definition": {}}}
        }}
    ]
}