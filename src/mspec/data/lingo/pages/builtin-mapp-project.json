{
    "lingo": {
        "version": "page-beta-1"
    },
    "params": {
        "project_name": {
            "name": {
                "lower_case": "project name"
            },
            "type": "str",
            "default": "My Lingo Project",
            "description": "Name of the Lingo project"
        },
        "module_names": {
            "name": {
                "lower_case": "module names"
            },
            "type": "list",
            "default": ["my-module-a", "my-module-b"],
            "description": "List of module names in the Lingo project",
            "item_type": "str"
        }
    },
    "state": {
        "header": {
            "type": "str",
            "calc": {
                "call": "join",
                "args": {
                    "separator": "",
                    "items": [":: ", {"params": {"project_name": {}}}]
                }
            }
        },
        "sorted_module_names": {
            "type": "list",
            "calc": {
                "call": "sorted",
                "args": {
                    "iterable": {"params": {"module_names": {}}}
                }
            }
        }
    },
    "ops": {},
    "output": [
        {
            "heading": {
                "state": {
                    "header": {}
                }
            },
            "level": 1
        },
        {"breadcrumbs": [
            {"params": {"project_name": {}}}
        ]},
        {
            "heading": ":: available modules",
            "level": 2
        },
        {
            "break": 1
        },
        {
            "text": "To Do: Fix sorting of module names",
            "style": {
                "bold": true,
                "color": "red"
            }
        },
        {
            "call": "map",
            "args": {
                "iterable": {
                    "state": {
                        "sorted_module_names": {}
                    }
                },
                "function": {
                    "link": {
                        "call": "concat",
                        "args": {
                            "items": [
                                "/",
                                {
                                    "self": "item"
                                }
                            ]
                        }
                    },
                    "text": {
                        "self": "item"
                    }
                }
            }
        }
    ]
}